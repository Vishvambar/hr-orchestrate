GITHUB_TOKEN=
GITHUB_MODEL=gpt-4o

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

ORCH_ROW_DELAY_SECONDS=3
ORCH_VISION_COOLDOWN_SECONDS=15
