## ── Groq (Primary + Last Resort) ──
GROQ_API_KEY=
# Primary: meta-llama/llama-4-scout-17b-16e-instruct
# Last resort: qwen/qwen3.6-27b (auto-selected by provider name)

## ── Google Gemini ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

## ── GitHub Models ──
GITHUB_TOKEN=
GITHUB_MODEL=gpt-4o

## ── OpenRouter ──
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free

## ── Orchestration Settings ──
# Provider failover order (left = highest priority)
ORCH_PROVIDER_ORDER=groq_llama,gemini,github_models,openrouter,groq_qwen

# Rate-limit mitigation
ORCH_ROW_DELAY_SECONDS=5
ORCH_VISION_COOLDOWN_SECONDS=15
ORCH_VISION_MAX_CYCLES=2

# Resume interrupted runs from existing output.csv
ORCH_RESUME_OUTPUT=true
